{
  "profiles": {
    "GtMotive.Estimate.Microservice.Host": {
      "commandName": "Project",
      "launchBrowser": true,
      "launchUrl": "swagger",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "applicationUrl": "https://localhost:14602;http://localhost:14603"
    },
    "Docker": {
      "commandName": "Docker",
      "launchBrowser": true,
      "launchUrl": "{Scheme}://{ServiceHost}:{ServicePort}",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://+:14602",
        "MongoDb__ConnectionString": "mongodb://admin:admin@host.docker.internal:27017",
        "AppSettings__LocalAuthTokenUrl": "http://localhost:14602/connect/token"
      },
      "httpPort": 14602,
      "useSSL": false
    }
  }
}